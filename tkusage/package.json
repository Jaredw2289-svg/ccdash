{
  "name": "tkusage",
  "version": "0.1.0",
  "description": "Unified local usage and cost estimation CLI for Claude Code and Codex",
  "type": "module",
  "bin": {
    "tkusage": "dist/tkusage.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --target=node --outfile=dist/tkusage.js --target-version=18",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "test": "vitest run"
  },
  "keywords": [
    "claude-code",
    "codex",
    "cli",
    "usage",
    "statusline"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
